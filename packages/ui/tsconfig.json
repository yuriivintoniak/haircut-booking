{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "paths": {
      "@repo/ui/*": ["./src/*"]
    },
    "resolvePackageJsonImports": true,
    "rootDir": "./src",
    "strictNullChecks": true,
    "target": "ES2023",
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
